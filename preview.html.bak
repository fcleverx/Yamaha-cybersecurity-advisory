<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>Preview - Awareness Newsletter</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
  <style>
    body{margin:0;background:#0a0a0a;color:#fff;font-family:'DM Sans',sans-serif}
    .wrap{max-width:1120px;margin:0 auto;padding:1rem}
    .btn{border:1px solid rgba(255,255,255,.2);background:transparent;color:#ddd;padding:.45rem .8rem;border-radius:6px;cursor:pointer}
    .btn.primary{border-color:#2627e0;color:#2627e0}
    .card{border:1px solid rgba(255,255,255,.12);border-radius:8px;background:#121212;padding:.8rem;margin-bottom:.7rem}
    .toolbar{display:flex;gap:.45rem;flex-wrap:wrap;align-items:center}
    .field{display:flex;flex-direction:column;gap:.28rem;min-width:230px}
    .field span{font-size:.68rem;color:#aaa;text-transform:uppercase;letter-spacing:.06em}
    input,select{background:#191919;border:1px solid rgba(255,255,255,.16);color:#fff;padding:.45rem .55rem;border-radius:6px}
    #project-version-label{font-size:.75rem;color:#2627e0}
    #lang-translating{display:none;font-size:.72rem;color:#2627e0}
    #lang-translating.active{display:inline}
    .preview{background:#111;border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:.7rem}
    #nl-out{max-width:700px;margin:0 auto;background:#fff;color:#000}
    @media (max-width: 640px){
      .wrap{padding:.65rem}
      .btn{flex:1;min-width:128px}
      .field{min-width:100%}
      #nl-out{max-width:100%}
    }
  </style>
</head>
<body>
  <div class="wrap">
    <h1 style="font-family:'DM Serif Display',serif;margin:.2rem 0 .8rem">Preview</h1>
    <div class="card">
      <div class="toolbar">
        <label class="field">
          <span>Project name</span>
          <input id="project-title" placeholder="newsletter_YYYY-MM-DD">
        </label>
        <span id="project-version-label">Unsaved project</span>
        <button class="btn primary" onclick="App.UI.saveProjectVersion()">Save Project</button>
        <button class="btn primary" onclick="App.UI.goToEditorPage()">Open in Editor</button>
        <button class="btn" onclick="App.UI.goToHomePage()">Home</button>
        <button class="btn" onclick="App.UI.goToProjectsPage()">Projects</button>
        <button class="btn" onclick="window.location.href='config.html'">Config</button>
      </div>
    </div>

    <div class="card">
      <div class="toolbar">
        <label class="field">
          <span>Language</span>
          <select id="preview-lang" onchange="App.UI.switchPreviewLanguage(this.value)"></select>
        </label>
        <span id="lang-translating">Translating...</span>
        <select id="wf-next-state"></select>
        <span id="wf-state-chip" style="padding:.3rem .6rem;border:1px solid #555;border-radius:999px">Draft</span>
        <button class="btn" onclick="App.UI.transitionWorkflow()">Move</button>
        <button class="btn" onclick="App.UI.downloadCurrentHTML()">Download</button>
        <button class="btn" onclick="App.UI.downloadAllHTML()" title="Download ZIP with html/ and svg/ folders">Download All</button>
        <button class="btn primary" onclick="App.UI.goToSendPage()">Send</button>
      </div>
      <div id="translation-pipeline-state" aria-live="polite" style="margin-top:.55rem"></div>
    </div>

    <div class="preview">
      <div class="nl" id="nl-out"></div>
    </div>
  </div>

  <input id="cfg-freq" value="Weekly" hidden><input id="cfg-soc" value="SOC-support@abc.com" hidden>
  <input id="cfg-max" value="2" hidden>
  <input id="cfg-org" value="ABC Corp" hidden>
  <input id="cfg-portal" value="https://security.abc.com/awareness" hidden>
  <input id="cfg-pname" value="ABC Security Awareness Portal" hidden>
  <input id="meta-title" hidden><input id="meta-issue-date" hidden><input id="meta-status" value="draft" hidden>
  <input id="feat-poster" type="checkbox" checked hidden><input id="feat-links" type="checkbox" checked hidden><input id="feat-qr" type="checkbox" checked hidden><input id="feat-illus" type="checkbox" checked hidden>
  <input id="feat-ai" type="checkbox" checked hidden><input id="ai-provider" value="claude" hidden><input id="ai-key" hidden>
  <input id="smtp-relay-url" hidden><input id="smtp-host" hidden><input id="smtp-port" value="587" hidden><input id="smtp-username" hidden><input id="smtp-password" hidden>
  <input id="smtp-from-name" value="Security Team" hidden><input id="smtp-from-address" hidden><input id="smtp-test-to" hidden><input id="smtp-send-to" hidden><input id="smtp-secure" type="checkbox" checked hidden>
  <select id="delivery-method" hidden><option value="smtp">SMTP relay (legacy)</option><option value="graph">Microsoft Graph (Outlook)</option></select>
  <input id="graph-tenant-id" hidden><input id="graph-client-id" hidden><input id="graph-client-secret" hidden>
  <div id="delivery-graph-panel" hidden></div><div id="delivery-smtp-panel" hidden></div>
  <div id="saved-drafts-list" hidden></div><div id="delivery-log-list" hidden></div><div id="db-stats" hidden></div><div id="feed-status-area" hidden></div><div id="feed-sources-dashboard" hidden></div><div id="sb-feeds-list" hidden></div><div id="articles-area" hidden></div>

  <script src="js/utils.js"></script>
  <script src="js/db.js"></script>
  <script src="js/router_nav.js"></script>
  <script src="js/ux_contract.js"></script>
  <script src="js/feed_scoring.js"></script>
  <script src="js/keyword_store.js"></script>
  <script src="js/project_store.js"></script>
  <script src="js/responsive_layout.js"></script>
  <script src="js/rss_fetcher.js"></script>
  <script src="js/ai_summarizer.js"></script>
  <script src="js/graphics_engine.js"></script>
  <script src="js/newsletter_builder.js"></script>
  <script src="js/translation_metrics.js"></script>
  <script src="js/delivery_helpers.js"></script>
  <script src="js/ui_controller.js"></script>
  <script src="js/editor.js"></script>
  <script>
    App.UXContract?.init({ pageId: 'preview', flowStepId: 'preview', guard: 'workspace-required' });
    if (App.ResponsiveLayout?.init) App.ResponsiveLayout.init();
    App.UI.init();
  </script>
</body>
</html>
